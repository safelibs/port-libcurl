<testcase>
<info>
<keywords>
HSTS
CURLOPT_HSTS
file
</keywords>
</info>

# Server-side
<reply>
<data1>
HTTP/1.1 200 OK
Content-Length: 4
Strict-Transport-Security: max-age=1

init
</data1>
<data2>
HTTP/1.1 200 OK
Content-Length: 5
Strict-Transport-Security: max-age=604800; includeSubDomains

-good
</data2>
</reply>

# Client-side
<client>
<features>
HSTS
https
</features>
<setenv>
CURL_HSTS_HTTP=yes
</setenv>
<server>
http
</server>
<name>
public HSTS file load save and reload replacement
</name>
<tool>
lib%TESTNUMBER
</tool>
<command>
%TESTNUMBER %HOSTIP %HTTPPORT %NOLISTENPORT %LOGDIR/hsts-%TESTNUMBER.txt
</command>
<file name="%LOGDIR/hsts-%TESTNUMBER.txt" mode="text">
# Your HSTS cache. https://curl.se/docs/hsts.html
# This file was generated by libcurl! Edit at your own risk.
keep.example "20370319 01:02:03"
</file>
</client>

<verify>
<errorcode>
0
</errorcode>
<protocol crlf="yes">
GET /%TESTNUMBER0001 HTTP/1.1
Host: clear.example:%HTTPPORT
Accept: */*

GET /%TESTNUMBER0002 HTTP/1.1
Host: goodhsts.example:%HTTPPORT
Accept: */*

</protocol>
<stdout>
https://sub.goodhsts.example:%NOLISTENPORT/not-there/%TESTNUMBER
</stdout>
<stripfile>
s/(\.goodhsts\.example) \"[^\"]*\"/$1 TIMESTAMP/
</stripfile>
<file name="%LOGDIR/hsts-%TESTNUMBER.txt" mode="text">
# Your HSTS cache. https://curl.se/docs/hsts.html
# This file was generated by libcurl! Edit at your own risk.
keep.example "20370319 01:02:03"
.goodhsts.example TIMESTAMP
</file>
</verify>
</testcase>
